{
  "name": "aegis-ui",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --webpack -H 127.0.0.1",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http-get://127.0.0.1:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
