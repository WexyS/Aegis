# ============================================================
# AEGIS — Environment Configuration
# Copy this file to .env and adjust values as needed.
# ============================================================

# --- Server ---
AEGIS_HOST=127.0.0.1
AEGIS_PORT=8400
AEGIS_ENV=development
AEGIS_DEBUG=true

# --- Safety ---
AEGIS_SAFE_MODE=true
AEGIS_DRY_RUN=true
AEGIS_REQUIRE_APPROVAL_HIGH_RISK=true

# --- Logging ---
AEGIS_LOG_DIR=./logs
AEGIS_LOG_LEVEL=DEBUG

# --- Local Model Backend ---
AEGIS_OLLAMA_BASE_URL=http://localhost:11434
AEGIS_DEFAULT_MODEL=qwen3:8b
AEGIS_CODE_MODEL=qwen2.5-coder:14b
AEGIS_EMBED_MODEL=nomic-embed-text

# --- Vector DB ---
AEGIS_VECTOR_DB_BACKEND=qdrant
AEGIS_QDRANT_URL=http://localhost:6333
AEGIS_QDRANT_COLLECTION=aegis_memory

# --- Cloud Fallback (disabled by default) ---
AEGIS_CLOUD_ENABLED=false
# AEGIS_OPENAI_API_KEY=
# AEGIS_ANTHROPIC_API_KEY=

# --- Memory ---
AEGIS_STM_MAX_TURNS=20
AEGIS_EPISODIC_RETENTION_DAYS=90
